modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "client-build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "client-test"

[[workflows.workflow]]
name = "test"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd EchoAI && npm test"

[[workflows.workflow]]
name = "client-build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd EchoAI && npm run build:client"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "client-test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd EchoAI/client && npm install && npm test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
