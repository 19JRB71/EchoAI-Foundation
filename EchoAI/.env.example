# ===========================================================================
# EchoAI Environment Variables Template
# Copy this file to ".env" and fill in real values. Never commit your real .env.
#
# CRITICAL vars (boot fails fast if missing): DATABASE_URL, JWT_SECRET,
# SESSION_SECRET, ENCRYPTION_KEY. Everything else degrades gracefully — a
# feature returns 503 / "not configured" until its vars are set.
# ===========================================================================

# --- Server ---------------------------------------------------------------
# Port the Express server listens on (Replit injects PORT automatically).
PORT=5000
# "development" or "production". Controls CORS strictness, cache headers, logs.
NODE_ENV=development

# --- Database (PostgreSQL) -------------------------------------------------
# Single connection string is all the app needs. The DB_* parts are optional
# conveniences for local tooling. Get this from your Postgres/Neon/Replit DB.
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/echoai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echoai
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Authentication (JWT) & Session ---------------------------------------
# CRITICAL. Long random strings. Generate each with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret
# How long an access token stays valid (e.g. 1d, 12h, 30m).
JWT_EXPIRES_IN=1d

# --- Credential Encryption (AES-256-GCM) ----------------------------------
# CRITICAL. Encrypts third-party tokens at rest. EXACTLY 64 hex chars (32 bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this after launch makes already-stored encrypted tokens unreadable.
ENCRYPTION_KEY=your_64_char_hex_encryption_key

# --- Rate limiting / uploads (optional tuning) ----------------------------
# Max requests per 15 min window across /api (default 1000).
RATE_LIMIT_MAX=1000
# Max failed login/register attempts per 15 min per IP (default 10).
AUTH_RATE_LIMIT_MAX=10
# Max accepted voice-upload size in bytes (default 26214400 = 25 MB).
MAX_AUDIO_UPLOAD_BYTES=26214400

# --- CORS / URLs ----------------------------------------------------------
# Comma-separated extra origins allowed in production (in addition to your
# Replit domains). Used for embedding / external clients.
ALLOWED_ORIGINS=https://app.echoai.com,https://www.echoai.com
# Public base URL of this server. Used to build absolute links in emails, the
# chatbot widget, public response pages, and webhook callback URLs.
PUBLIC_BASE_URL=https://app.echoai.com
# Base URL used for dashboard links / CTA buttons inside outbound emails.
APP_URL=https://app.echoai.com

# --- Admin Seeder ---------------------------------------------------------
# On first startup the server creates this admin account if it does not exist.
ADMIN_EMAIL=admin@echoai.com
ADMIN_PASSWORD=change_this_admin_password

# --- Anthropic (text AI agents) -------------------------------------------
# Get from https://console.anthropic.com/. Powers brand discovery and every
# AI text agent. Without it those features return 502/503.
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI (DALL-E images + voice STT/TTS) -------------------------------
# Get from https://platform.openai.com/api-keys.
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# --- Stripe (Payments & Subscriptions) ------------------------------------
# Get keys from https://dashboard.stripe.com/apikeys.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Publishable key is also consumed by the React client (billing UI).
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Get after creating a webhook endpoint (see DEPLOYMENT.md).
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Price IDs for each tier (create recurring monthly Prices in the Stripe
# dashboard). STARTER=$100, PRO=$350, ENTERPRISE=$550. GROWTH is legacy.
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id
STRIPE_PRICE_GROWTH=price_your_legacy_growth_price_id
# Per-seat add-on price ($50/seat/month). Seat billing no-ops if unset.
STRIPE_PRICE_SEAT=price_your_per_seat_price_id

# --- Facebook / Meta Marketing API ----------------------------------------
# Create an app at https://developers.facebook.com/. App ID/secret power
# "Continue with Facebook" ad-account linking; the access token + page/link are
# used when pushing initial ad creatives.
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_LINK_URL=https://your-landing-page.example.com
FACEBOOK_GRAPH_VERSION=v21.0
# OAuth callback registered in the Facebook app (must match exactly).
FACEBOOK_REDIRECT_URI=https://app.echoai.com/api/facebook/oauth/callback
# Target cost-per-lead used by the optimization agent (account currency).
TARGET_COST_PER_LEAD=20

# --- Google (OAuth read APIs + SEO + Ads token) ---------------------------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://app.echoai.com/api/google/oauth/callback
# Optional: Google Ads developer token for ad-account reads.
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# --- Email (Nodemailer / SMTP transactional email) ------------------------
# Any SMTP provider (SendGrid, Mailgun, Postmark, Gmail SMTP, etc.).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=EchoAI <no-reply@echoai.com>
# Max delivery retry attempts per message (default 3).
EMAIL_MAX_RETRIES=3

# --- Web Push (PWA browser notifications, VAPID) --------------------------
# Generate a key pair once with:  npx web-push generate-vapid-keys
# Keep these STABLE after launch — rotating them invalidates all existing
# browser push subscriptions.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@echoai.com

# --- Firebase Cloud Messaging (native mobile push) ------------------------
# Server key from the Firebase console → Project settings → Cloud Messaging.
# Mobile push degrades gracefully (skips) when unset.
FCM_SERVER_KEY=your_fcm_server_key

# --- Twilio (Phone agent & SMS) -------------------------------------------
# Twilio credentials are stored PER BRAND (encrypted in the DB), not as global
# env vars. The only global Twilio toggle is below.
# Set to "true" ONLY in local dev to bypass inbound webhook signature checks.
# MUST be unset/false in production so Twilio signatures are enforced.
TWILIO_SKIP_VALIDATION=false

# --- Replit platform (auto-provided in the Replit environment) -------------
# These are injected by Replit; you normally do NOT set them by hand. Listed
# so production CORS / public-URL behavior is understood.
# REPLIT_DOMAINS=your-app.replit.app
# REPLIT_DEV_DOMAIN=your-dev-domain.replit.dev
