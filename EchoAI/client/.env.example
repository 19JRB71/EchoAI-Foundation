# Base URL for the EchoAI backend API. Leave empty to use the same origin.
# In development the Vite dev server proxies /api to http://localhost:5000,
# so this can stay blank locally.
VITE_API_BASE_URL=

# Stripe publishable key (pk_test_... or pk_live_...). Used by the
# onboarding subscription step to collect card details via Stripe Elements.
VITE_STRIPE_PUBLISHABLE_KEY=
